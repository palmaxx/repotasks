{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RepoTasks",
  "version": "0.1.0",
  "identifier": "io.github.palmaxx.repotasks",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "RepoTasks",
        "width": 360,
        "height": 560,
        "minWidth": 300,
        "minHeight": 360,
        "resizable": true,
        "alwaysOnTop": true
      },
      {
        "label": "capture",
        "title": "RepoTasks — Quick Add",
        "width": 480,
        "height": 240,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; ipc-src 'self';"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
